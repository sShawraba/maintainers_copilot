# Widget Environment Configuration
# Copy this to .env.local and adjust for your environment

# Development
VITE_API_URL=http://localhost:8000
VITE_WIDGET_ID=dev-widget
VITE_POSITION=bottom-right
VITE_THEME=light

# Staging (if needed)
# VITE_API_URL=https://staging-api.yourdomain.com
# VITE_WIDGET_ID=staging-widget

# Production (if needed)
# VITE_API_URL=https://api.yourdomain.com
# VITE_WIDGET_ID=prod-widget
